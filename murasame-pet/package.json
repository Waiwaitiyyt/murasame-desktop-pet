{
  "name": "murasame-pet",
  "version": "1.0.1",
  "description": "丛雨桌面宠物 - 千恋*万花",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.murasame.pet",
    "productName": "丛雨桌宠",
    "files": ["**/*"],
    "extraResources": [
      { "from": "../fgimages", "to": "fgimages" }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
